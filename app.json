{
  "expo": {
    "name": "One Life",
    "slug": "one-life",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "onelife",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "splash": {
      "backgroundColor": "#0c0c0c",
      "resizeMode": "contain",
      "image": "./assets/images/splash-icon.png"
    },
    "ios": {
      "icon": "./assets/images/icon.png",
      "supportsTablet": false,
      "bundleIdentifier": "com.vmutafchiev.onelife"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0c0c0c",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.yourname.onelife"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0c0c0c",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4ff7b264-e6c4-4220-83e9-520d1ff4612f"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4ff7b264-e6c4-4220-83e9-520d1ff4612f"
    }
  }
}
